    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 3,
      "title": "Staff Sales Ranking (Top 10)",
      "type": "barchart",
      "options": { "orientation": "horizontal" },
      "targets": [{ 
        "format": "table", 
        "rawSql": "SELECT st.name, SUM(o.final_price) as value FROM orders o JOIN staffs st ON o.staff_referral = st.id GROUP BY st.name ORDER BY value DESC LIMIT 10", 
        "refId": "A" 
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
