      "id": 2,
      "title": "Sales Performance by Store Location",
      "type": "barchart",
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ 
        "format": "table", 
        "rawSql": "SELECT s.location, SUM(o.final_price) as value FROM orders o JOIN stores s ON o.store_id = s.id GROUP BY s.location", 
        "refId": "A" 
      }]
