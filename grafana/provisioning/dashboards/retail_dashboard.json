      "targets": [{ 
        "format": "table", 
        "rawSql": "SELECT AVG(rating) FROM reviews", 
        "refId": "A" 
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 6,
      "title": "Deep Audit Log (Complex Query)",
      "type": "table",
      "targets": [{ 
        "format": "table", 
        "rawSql": "SELECT o.id, c.name as customer, s.location, st.name as staff, pr.code as promo, o.final_price FROM orders o JOIN customers c ON o.customer_id = c.id JOIN stores s ON o.store_id = s.id JOIN staffs st ON o.staff_referral = st.id LEFT JOIN promotions pr ON o.promotion_id = pr.id ORDER BY o.id DESC LIMIT 100", 
        "refId": "A" 
      }]
    }
