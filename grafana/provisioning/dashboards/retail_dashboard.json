    {
       "datasource": { "type": "postgres", "uid": "PostgreSQL" },
       "gridPos": { "h": 5, "w": 9, "x": 15, "y": 1 },
       "id": 3,
       "title": "Store Revenue Heatmap (City)",
       "type": "bargauge",
       "targets": [{ "format": "table", "rawSql": "SELECT s.location as metric, SUM(o.final_price) as value FROM orders o JOIN stores s ON o.store_id = s.id GROUP BY s.location", "refId": "A" }]
    },
    
    { "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "title": "🚚 2. LOGISTICS, REFUNDS & PROMOTIONS", "type": "row" },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "id": 4,
      "title": "Refund Reasons Analysis",
      "type": "piechart",
      "targets": [{ "format": "table", "rawSql": "SELECT reason as metric, COUNT(id) as value FROM refunds GROUP BY reason", "refId": "A" }]
    },
    {
       "datasource": { "type": "postgres", "uid": "PostgreSQL" },
       "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
       "id": 5,
       "title": "Carrier Latency Performance (Avg Days)",
       "type": "barchart",
       "targets": [{ "format": "table", "rawSql": "SELECT carrier as name, AVG(estimated_days) as value FROM shippings GROUP BY carrier", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "id": 6,
      "title": "Promotion Campaign Reach",
      "type": "piechart",
      "targets": [{ "format": "table", "rawSql": "SELECT COALESCE(p.code, 'No Promo') as metric, COUNT(o.id) as value FROM orders o LEFT JOIN promotions p ON o.promotion_id = p.id GROUP BY p.code", "refId": "A" }]
    },

    { "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "title": "🏢 3. STAFF & PRODUCT PERFORMANCE", "type": "row" },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 7,
      "title": "Top Performing Staff (Revenue Generators)",
      "type": "barchart",
      "options": { "orientation": "horizontal" },
      "targets": [{ "format": "table", "rawSql": "SELECT st.name, SUM(o.final_price) as value FROM orders o JOIN staffs st ON o.staff_referral = st.id GROUP BY st.name ORDER BY value DESC LIMIT 10", "refId": "A" }]
    },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 8,
      "title": "Best Selling Products",
      "type": "table",
      "targets": [{ "format": "table", "rawSql": "SELECT p.name, p.category, SUM(oi.quantity) as sold FROM order_items oi JOIN products p ON oi.product_id = p.id GROUP BY p.id ORDER BY sold DESC LIMIT 10", "refId": "A" }]
    },
    
    { "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "title": "👑 4. CUSTOMER LOYALTY & SENTIMENT", "type": "row" },
