      "title": "Promotion Effectiveness (Discount Usage)",
      "type": "piechart",
      "targets": [{ 
        "format": "table", 
        "rawSql": "SELECT p.code as metric, COUNT(o.id) as value FROM orders o JOIN promotions p ON o.promotion_id = p.id GROUP BY p.code", 
        "refId": "A" 
      }]
    },
    {
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
